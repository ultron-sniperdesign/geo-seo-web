---
import PageLayout from "~/layouts/PageLayout.astro";
import Section from "~/components/Section.astro";
import Container from "~/components/Container.astro";
import AnswerBlock from "~/components/AnswerBlock.astro";
import Prose from "~/components/Prose.astro";
import CTABanner from "~/components/CTABanner.astro";
import { services, type Service } from "~/data/services";
import { serviceJsonLd, breadcrumbJsonLd } from "~/lib/jsonld";

export function getStaticPaths() {
  return services
    .filter((s) => s.slug !== "audit" && s.valueProp)
    .map((s) => ({ params: { slug: s.slug }, props: { service: s } }));
}

interface Props {
  service: Service;
}
const { service } = Astro.props;

const crumbs = [{ label: "Služby", href: "/sluzby/" }, { label: service.title }];
const jsonLd = [
  serviceJsonLd({
    name: service.title,
    description: service.valueProp ?? service.blurb,
    url: `/sluzby/${service.slug}/`,
  }),
  breadcrumbJsonLd(crumbs),
];
---

<PageLayout
  title={`${service.title} — služba | geo-seo.cz`}
  description={service.valueProp}
  eyebrow="Služby"
  heading={service.title}
  lead={service.valueProp}
  crumbs={crumbs}
  jsonLd={jsonLd}
>
  <Section>
    <Container size="prose">
      <AnswerBlock label="Co to je" text={service.valueProp ?? ""} />
      <Prose class="mt">
        <h2>Co služba obsahuje</h2>
        <ul>
          {(service.contains ?? []).map((c) => <li>{c}</li>)}
        </ul>
        <h2>Pro koho</h2>
        <p>{service.forWhom}</p>
        <h2>Jak to probíhá</h2>
        <p>{service.model}</p>
        <p>
          Začíná se ale vždy <a href="/audit/">Auditem</a> — ten ukáže, jestli a kde tahle
          služba dává smysl jako první.
        </p>
      </Prose>
    </Container>
  </Section>

  <Section>
    <Container>
      <CTABanner
        title="Začněte <strong>Auditem</strong>"
        text="Audit ukáže, kterou službu řešit jako první — konkrétní plán pro váš web."
        primaryLabel="Objednat GEO audit"
        primaryHref="/audit/"
        secondaryLabel="Přehled služeb →"
        secondaryHref="/sluzby/"
      />
    </Container>
  </Section>
</PageLayout>

<style>
  .mt { margin-top: 2rem; }
</style>
