---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Section from "~/components/Section.astro";
import Container from "~/components/Container.astro";
import Hero from "~/components/Hero.astro";
import AnswerBlock from "~/components/AnswerBlock.astro";
import SectionHeading from "~/components/SectionHeading.astro";
import Stats from "~/components/Stats.astro";
import ServiceCard from "~/components/ServiceCard.astro";
import ProcessSteps from "~/components/ProcessSteps.astro";
import AuthorityStrip from "~/components/AuthorityStrip.astro";
import CTABanner from "~/components/CTABanner.astro";
import { services } from "~/data/services";

const stats = [
  { value: "+645 %", label: "meziroční růst hledanosti geo seo (CZ)" },
  { value: "+300 %", label: "meziroční růst generative engine optimization" },
  { value: "78 %", label: "firem má nulovou viditelnost v AI" },
  { value: "~68 %", label: "AI citací pochází z third-party zdrojů" },
];

const steps = [
  { num: "1", title: "Edukace", text: "Pochopíte, jak vás AI vybírá a cituje. Začněte sekcemi Co je GEO a GEO návod." },
  { num: "2", title: "Audit", text: "Zjistíte, kde stojíte v AI viditelnosti a co řešit jako první — prioritizovaný plán." },
  { num: "3", title: "Realizace", text: "Uděláme to za vás: SEO základ, GEO obsah, technická úprava i dlouhodobá správa." },
];
---

<BaseLayout
  title="GEO SEO — dostaňte se do odpovědí AI | geo-seo.cz"
  description="GEO (Generative Engine Optimization) do hloubky: jak vás cituje ChatGPT, Perplexity, Claude a Google AI Overviews. Audit a služby od agentury Sniper Design."
>
  <Hero />

  <Section bg="tint">
    <Container>
      <AnswerBlock
        text="<strong>GEO (Generative Engine Optimization)</strong> je optimalizace obsahu tak, aby ho generativní AI — ChatGPT, Perplexity, Claude, Google AI Overviews — používala jako zdroj a citovala. Na rozdíl od klasického SEO, které cílí na pozice ve výsledcích, GEO cílí na to, aby vás AI zmínila ve své odpovědi."
      />
    </Container>
  </Section>

  <Section>
    <Container>
      <SectionHeading
        eyebrow="Proč teď"
        title="Nika, která <strong>prudce roste</strong>"
        lead="GEO je emerging — nízké absolutní objemy, ale raketový růst. Kdo je v&nbsp;AI odpovědích teď, drží náskok."
      />
      <Stats items={stats} />
    </Container>
  </Section>

  <Section bg="deep">
    <Container>
      <SectionHeading
        eyebrow="Co umíme"
        title="Od auditu k <strong>realizaci</strong>"
        lead="Začíná se Auditem — zjistíte, kde stojíte. Na něj navazují 4&nbsp;dlouhodobé služby."
      />
      <div class="services-grid">
        {services.map((s) => (
          <ServiceCard title={s.title} blurb={s.blurb} href={s.href} featured={s.featured} tag={s.tag} />
        ))}
      </div>
    </Container>
  </Section>

  <Section>
    <Container>
      <SectionHeading eyebrow="Jak to funguje" title="Edukace → Audit → <strong>realizace</strong>" />
      <ProcessSteps steps={steps} />
    </Container>
  </Section>

  <Section bg="deep">
    <Container>
      <AuthorityStrip />
    </Container>
  </Section>

  <Section>
    <Container>
      <CTABanner
        title="Necituje vás AI? <strong>Začněte auditem.</strong>"
        text="GEO/SEO Audit vám ukáže, proč vás generativní AI přehlíží a co řešit jako první — konkrétní plán, ne obecné rady."
        primaryLabel="Objednat GEO audit"
        primaryHref="/audit/"
        secondaryLabel="Nejdřív si přečíst GEO návod →"
        secondaryHref="/geo-navod/"
      />
    </Container>
  </Section>
</BaseLayout>

<style>
  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 620px) { .services-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1000px) { .services-grid { grid-template-columns: repeat(3, 1fr); } }
</style>
