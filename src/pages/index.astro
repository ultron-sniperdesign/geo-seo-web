---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Section from "~/components/Section.astro";
import Container from "~/components/Container.astro";
import Hero from "~/components/Hero.astro";
import AnswerBlock from "~/components/AnswerBlock.astro";
import SectionHeading from "~/components/SectionHeading.astro";
import Stats from "~/components/Stats.astro";
import ServiceCard from "~/components/ServiceCard.astro";
import ProcessSteps from "~/components/ProcessSteps.astro";
import AuthorityStrip from "~/components/AuthorityStrip.astro";
import CTABanner from "~/components/CTABanner.astro";
import { services } from "~/data/services";

const stats = [
  { value: "+645 %", label: "meziroční růst hledanosti geo seo (CZ)" },
  { value: "+300 %", label: "meziroční růst generative engine optimization" },
  { value: "78 %", label: "firem má nulovou viditelnost v AI" },
  { value: "~68 %", label: "AI citací pochází z third-party zdrojů" },
];

const steps = [
  { num: "1", title: "Edukace", text: "Pochopíte, jak vás AI vybírá a cituje. Začněte sekcemi Co je GEO a GEO návod." },
  { num: "2", title: "Audit", text: "Zjistíte, kde stojíte v AI viditelnosti a co řešit jako první — prioritizovaný plán." },
  { num: "3", title: "Realizace", text: "Uděláme to za vás: SEO základ, GEO obsah, technická úprava i dlouhodobá správa." },
];
---

<BaseLayout
  title="GEO SEO — dostaňte se do odpovědí AI | geo-seo.cz"
  description="GEO (Generative Engine Optimization) do hloubky: jak vás cituje ChatGPT, Perplexity, Claude a Google AI Overviews. Audit a služby od agentury Sniper Design."
>
  <Hero />

  <Section bg="tint" class="answer-feature">
    <div class="answer-deco" aria-hidden="true">
      <svg class="cflow" viewBox="0 0 440 260" fill="none" focusable="false" preserveAspectRatio="xMidYMid meet">
        <!-- ambient částice (fill) -->
        <g class="cflow__amb">
          <circle cx="44" cy="40" r="2" /><circle cx="120" cy="214" r="2.4" />
          <circle cx="206" cy="56" r="1.8" /><circle cx="72" cy="120" r="1.6" />
          <circle cx="300" cy="28" r="2" /><circle cx="414" cy="44" r="2.2" />
          <circle cx="360" cy="232" r="2" /><circle cx="170" cy="196" r="1.6" />
        </g>
        <!-- světelná linka: zdroj (vlevo, = obsah) → odpověď -->
        <path class="cflow__beam" d="M0 150 C 110 150, 175 144, 250 140" />
        <!-- úryvky letící do odpovědi -->
        <g class="cflow__chips">
          <rect class="cflow__chip" x="0" y="133" width="40" height="14" rx="7" />
          <rect class="cflow__chip" x="0" y="133" width="40" height="14" rx="7" />
          <rect class="cflow__chip" x="0" y="133" width="40" height="14" rx="7" />
        </g>
        <!-- karta „Odpověď AI" s citací -->
        <g class="cflow__ans">
          <rect class="cflow__card" x="248" y="44" width="186" height="178" rx="14" />
          <circle class="cflow__dot" cx="270" cy="70" r="5" />
          <text class="cflow__ai" x="285" y="74">Odpověď AI</text>

          <!-- citovaný úryvek v uvozovkách -->
          <text class="cflow__quote" x="262" y="130">„</text>
          <rect class="cflow__line" x="288" y="100" width="126" height="7" rx="3.5" />
          <rect class="cflow__line" x="288" y="118" width="104" height="7" rx="3.5" />
          <text class="cflow__quote" x="396" y="116">“</text>

          <!-- zdroj citace -->
          <line class="cflow__div" x1="270" y1="150" x2="414" y2="150" />
          <g class="cflow__cite">
            <text class="cflow__zlabel" x="270" y="170">ZDROJ</text>
            <circle class="cflow__globe" cx="276" cy="190" r="5.5" />
            <text class="cflow__src" x="290" y="194">geo-seo.cz</text>
          </g>
        </g>
      </svg>
    </div>
    <Container class="answer-feature__content">
      <AnswerBlock
        text="<strong>GEO (Generative Engine Optimization)</strong> je optimalizace obsahu tak, aby ho generativní AI — ChatGPT, Perplexity, Claude, Google AI Overviews — používala jako zdroj a citovala. Na rozdíl od klasického SEO, které cílí na pozice ve výsledcích, GEO cílí na to, aby vás AI zmínila ve své odpovědi."
      />
    </Container>
  </Section>

  <Section>
    <Container>
      <SectionHeading
        eyebrow="Proč teď"
        title="Příležitost, která <strong>prudce roste</strong>"
        lead="GEO je emerging — nízké absolutní objemy, ale raketový růst. Kdo je v&nbsp;AI odpovědích teď, drží náskok."
      />
      <Stats items={stats} />
    </Container>
  </Section>

  <Section bg="deep">
    <Container>
      <SectionHeading
        eyebrow="Co umíme"
        title="Od auditu k <strong>realizaci</strong>"
        lead="Začíná se Auditem — zjistíte, kde stojíte. Na něj navazují 4&nbsp;dlouhodobé služby."
      />
      <div class="services-grid">
        {services.map((s) => (
          <ServiceCard title={s.title} blurb={s.blurb} href={s.href} featured={s.featured} tag={s.tag} />
        ))}
      </div>
    </Container>
  </Section>

  <Section>
    <Container>
      <SectionHeading eyebrow="Jak to funguje" title="Edukace → Audit → <strong>realizace</strong>" />
      <ProcessSteps steps={steps} />
    </Container>
  </Section>

  <Section bg="deep">
    <Container>
      <AuthorityStrip />
    </Container>
  </Section>

  <Section>
    <Container>
      <CTABanner
        title="Necituje vás AI? <strong>Začněte auditem.</strong>"
        text="GEO/SEO Audit vám ukáže, proč vás generativní AI přehlíží a co řešit jako první — konkrétní plán, ne obecné rady."
        primaryLabel="Objednat GEO audit"
        primaryHref="/audit/"
        secondaryLabel="Nejdřív si přečíst GEO návod →"
        secondaryHref="/geo-navod/"
      />
    </Container>
  </Section>
</BaseLayout>

<style>
  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 620px) { .services-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1000px) { .services-grid { grid-template-columns: repeat(3, 1fr); } }

  /* === Sekce „Stručná odpověď" — citační tok (zdroj → úryvek → citace) === */
  :global(.section.answer-feature) {
    position: relative; overflow: hidden; isolation: isolate;
    background: oklch(0.19 0.025 215); /* tmavé teal-slate */
  }
  :global(.answer-feature__content) { position: relative; z-index: 1; }

  .answer-deco { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
  .cflow {
    position: absolute; top: 50%; right: clamp(0.5rem, 4vw, 4rem);
    transform: translateY(-50%);
    width: min(56%, 40rem); height: auto; overflow: visible;
    --gb: oklch(0.84 0.18 150); /* jasná zelená pro glow na tmavém */
  }

  /* ambient částice */
  .cflow__amb circle { fill: oklch(0.7 0.08 200); animation: cflow-twinkle 5s var(--ease-out) infinite; }
  .cflow__amb circle:nth-child(2n) { fill: oklch(0.75 0.12 150); animation-delay: 1.2s; }
  .cflow__amb circle:nth-child(3n) { animation-delay: 2.4s; }

  /* světelná linka */
  .cflow__beam {
    stroke: var(--gb); stroke-opacity: 0.5; stroke-width: 1.5;
    stroke-dasharray: 4 8; animation: cflow-beam 1s linear infinite;
  }

  /* letící úryvky */
  .cflow__chip {
    fill: var(--gb);
    filter: drop-shadow(0 0 5px oklch(0.84 0.18 150 / 0.7));
    animation: cflow-chip 4.5s ease-in-out infinite;
  }
  .cflow__chip:nth-of-type(2) { animation-delay: 1.5s; }
  .cflow__chip:nth-of-type(3) { animation-delay: 3s; }

  /* karta odpovědi */
  .cflow__card { fill: oklch(0.24 0.02 215); stroke: oklch(0.62 0.05 200 / 0.4); stroke-width: 1; }
  .cflow__dot { fill: oklch(0.62 0.13 250); }
  .cflow__ai { fill: oklch(0.82 0.015 220); font-family: var(--font-mono); font-size: 13px; font-weight: 600; }
  .cflow__line { fill: oklch(0.44 0.02 215); }

  /* citace — rozsvítí se při příletu úryvku */
  .cflow__quote { fill: var(--gb); font-family: var(--font-sans); font-size: 30px; font-weight: 700; opacity: 0.7; }
  .cflow__div { stroke: oklch(0.55 0.04 205 / 0.4); stroke-width: 1; }
  .cflow__zlabel { fill: oklch(0.62 0.04 205); font-family: var(--font-mono); font-size: 9px; font-weight: 600; letter-spacing: 1.2px; }
  .cflow__globe { fill: var(--gb); }
  .cflow__src { fill: var(--gb); font-family: var(--font-mono); font-size: 13px; font-weight: 600; }
  .cflow__cite { animation: cflow-cite 1.5s ease-in-out infinite; }

  @keyframes cflow-beam { to { stroke-dashoffset: -12; } }
  @keyframes cflow-chip {
    0%   { transform: translate(0, 0) scale(1);          opacity: 0; }
    12%  { opacity: 1; }
    84%  { transform: translate(232px, -8px) scale(1);   opacity: 1; }
    96%  { transform: translate(246px, -10px) scale(0.55); opacity: 0; }
    100% { transform: translate(246px, -10px) scale(0.55); opacity: 0; }
  }
  @keyframes cflow-cite {
    0%, 100% { opacity: 0.58; }
    28%      { opacity: 1; }
  }
  @keyframes cflow-twinkle {
    0%, 100% { opacity: 0.25; }
    50% { opacity: 0.8; }
  }

  @media (max-width: 820px) { .cflow { display: none; } }
  @media (prefers-reduced-motion: reduce) {
    .cflow__beam, .cflow__chip, .cflow__cite, .cflow__amb circle { animation: none !important; }
    .cflow__chip { opacity: 0; }
    .cflow__chip:first-of-type { opacity: 1; transform: translateX(150px); }
  }
</style>
