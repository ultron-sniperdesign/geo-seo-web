---
import PageLayout from "~/layouts/PageLayout.astro";
import Section from "~/components/Section.astro";
import Container from "~/components/Container.astro";
import Prose from "~/components/Prose.astro";
import { breadcrumbJsonLd } from "~/lib/jsonld";

const crumbs = [{ label: "GDPR" }];
const jsonLd = [breadcrumbJsonLd(crumbs)];
---

<PageLayout
  title="Zásady zpracování osobních údajů (GDPR) | geo-seo.cz"
  description="Jak geo-seo.cz (provozovatel CPU s.r.o.) zpracovává osobní údaje z poptávkového formuláře. Účel, právní základ, doba uchování a vaše práva."
  eyebrow="Právní"
  heading="Zásady zpracování osobních údajů"
  lead="Jak nakládáme s údaji, které nám pošlete přes poptávkový formulář."
  crumbs={crumbs}
  jsonLd={jsonLd}
>
  <Section>
    <Container size="prose">
      <Prose>
        <h2>Správce údajů</h2>
        <p>
          Správcem je <strong>CPU s.r.o.</strong> (agentura Sniper Design), IČO 08125163, plátce
          DPH, sídlem Akademická 663/5, 108 00 Praha 10. Kontakt:
          <a href="mailto:aiseo-optimalizace@sniperdesign.cz">aiseo-optimalizace@sniperdesign.cz</a>.
        </p>

        <h2>Jaké údaje zpracováváme</h2>
        <p>
          Pouze údaje, které nám sami zadáte v poptávkovém formuláři: jméno, e-mail, případně
          adresu webu a text zprávy.
        </p>

        <h2>Účel a právní základ</h2>
        <p>
          Údaje používáme výhradně k vyřízení vaší poptávky a komunikaci o ní. Právním základem
          je jednání o uzavření smlouvy na vaši žádost a náš oprávněný zájem odpovědět na poptávku.
        </p>

        <h2>Doba uchování</h2>
        <p>
          Údaje uchováváme po dobu nezbytnou k vyřízení poptávky a navazující komunikace, poté je
          mažeme (nebo dle zákonných lhůt, pokud vznikne smluvní vztah).
        </p>

        <h2>Vaše práva</h2>
        <p>
          Máte právo na přístup k údajům, jejich opravu, výmaz, omezení zpracování a vznesení
          námitky. Pro uplatnění práv stačí napsat na
          <a href="mailto:aiseo-optimalizace@sniperdesign.cz">aiseo-optimalizace@sniperdesign.cz</a>.
        </p>

        <p>
          <em>Tato verze je základní; finální znění bude doplněno před spuštěním kampaní.</em>
        </p>
      </Prose>
    </Container>
  </Section>
</PageLayout>
