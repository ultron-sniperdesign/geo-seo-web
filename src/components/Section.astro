---
/**
 * Section.astro — sekce s konzistentním vertikálním paddingem + background
 * varianty (bg prop). Sekce se smí prolínat tmavší/světlejší pro rytmus
 * (design mantinel: světlý základ, ale střídání povolené).
 */
interface Props {
  bg?: "paper" | "deep" | "tint" | "ink";
  id?: string;
  class?: string;
}
const { bg = "paper", id, class: cls = "" } = Astro.props;
---

<section class:list={["section", `section--${bg}`, cls]} id={id}>
  <slot />
</section>

<style>
  .section { padding-block: var(--space-section-y); }
  .section--paper { background: var(--color-paper); }
  .section--deep { background: var(--color-paper-deep); }
  .section--tint { background: var(--color-accent-tint); }
  .section--ink { background: var(--color-ink); color: var(--color-paper); }
</style>
