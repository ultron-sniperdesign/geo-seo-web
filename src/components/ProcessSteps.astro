---
/**
 * ProcessSteps.astro — číslované kroky procesu (funnel: edukace → audit → realizace).
 */
interface Step {
  num: string;
  title: string;
  text: string;
}
interface Props {
  steps: Step[];
}
const { steps } = Astro.props;
---

<ol class="steps">
  {steps.map((s) => (
    <li class="step">
      <span class="step__num">{s.num}</span>
      <div class="step__body">
        <h3 class="step__title">{s.title}</h3>
        <p class="step__text">{s.text}</p>
      </div>
    </li>
  ))}
</ol>

<style>
  .steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  .step {
    display: flex;
    gap: 1rem;
    padding: 1.4rem 1.4rem 1.3rem;
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-lg);
  }
  .step__num {
    flex: none;
    display: grid;
    place-items: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: var(--radius-md);
    background: var(--color-accent-tint);
    color: var(--color-accent-strong);
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 1rem;
  }
  .step__title { font-size: 1.05rem; font-weight: 600; margin-bottom: 0.3rem; }
  .step__text { margin: 0; font-size: 0.92rem; line-height: 1.55; color: var(--color-ink-muted); }
  @media (min-width: 820px) {
    .steps { grid-template-columns: repeat(3, 1fr); }
  }
</style>
