---
/**
 * Hero.astro (homepage) — informačně bohatý rozcestník. H1 vždy "GEO SEO".
 * 2 sloupce: obsah + vizuál (CSS chat scéna: dotaz → odpověď AI s odkazem geo-seo.cz).
 * 2 CTA + quick-links do více sekcí (design mantinel: hero odvádí do sekcí).
 */
import Container from "~/components/Container.astro";
import Section from "~/components/Section.astro";
import Button from "~/components/Button.astro";

const quickLinks = [
  { label: "Co je GEO", href: "/co-je-geo/" },
  { label: "GEO návod", href: "/geo-navod/" },
  { label: "Platformy", href: "/platformy/" },
];
---

<Section class="hero">
  <Container>
    <div class="hero__grid">
      <div class="hero__content">
        <span class="hero__eyebrow">Generative Engine Optimization</span>
        <h1 class="hero__title">
          GEO SEO: dostaňte se do <span class="hero__hl">odpovědí&nbsp;AI</span>
        </h1>
        <p class="hero__lead">
          Klasické SEO řeší pozice v&nbsp;Googlu. <strong>GEO (Generative Engine
          Optimization)</strong> řeší, jestli vás zmíní a&nbsp;ocituje ChatGPT,
          Perplexity, Claude a&nbsp;Google AI&nbsp;Overviews. Ukážeme vám, jak na&nbsp;to —
          nebo to uděláme za&nbsp;vás.
        </p>
        <div class="hero__cta">
          <Button variant="primary" size="lg" href="/audit/" arrow>Objednat GEO audit</Button>
          <Button variant="secondary" size="lg" href="/co-je-geo/">Co je GEO SEO</Button>
        </div>
        <div class="hero__quick">
          <span class="hero__quick-label">Kam dál:</span>
          {quickLinks.map((l) => <a class="hero__chip" href={l.href}>{l.label}</a>)}
        </div>
      </div>

      <div class="hero__visual" aria-hidden="true">
        <div class="visual-cue">
          <p class="visual-cue__label">Jak funguje <strong>GEO&nbsp;SEO</strong> v&nbsp;praxi</p>
          <svg class="visual-cue__arrow" viewBox="0 0 50 54" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
            <path d="M25 5 C 13 17, 37 27, 25 43" />
            <path d="M25 43 l -8 -8 M25 43 l 8 -8" />
          </svg>
        </div>
        <figure class="chat">
          <div class="chat__head">
            <span class="chat__avatar">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
                <path d="M12 2l1.6 4.4L18 8l-4.4 1.6L12 14l-1.6-4.4L6 8l4.4-1.6L12 2Z" />
                <path d="M18.5 13l.9 2.4 2.4.9-2.4.9-.9 2.4-.9-2.4-2.4-.9 2.4-.9.9-2.4Z" />
              </svg>
            </span>
            <span class="chat__name">Odpověď&nbsp;AI</span>
            <span class="chat__tag">ukázka</span>
          </div>
          <div class="chat__thread">
            <p class="chat__bubble chat__bubble--user">Jak se dostat do&nbsp;odpovědí&nbsp;AI?</p>
            <p class="chat__bubble chat__bubble--ai">
              Zaměřte se na kvalitní obsah, který odpovídá na konkrétní dotazy lidí.
              Pomůže vám to být vidět nejen ve&nbsp;vyhledávání, ale i&nbsp;v&nbsp;odpovědích&nbsp;AI.
              Více tipů najdete na <span class="chat__link">geo‑seo.cz</span>
              nebo si přečtěte <span class="chat__link chat__link--muted">návod na&nbsp;GEO&nbsp;SEO</span>.
            </p>
          </div>
          <figcaption class="chat__note">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
              <path d="M12 19V5M12 5l-6 6M12 5l6 6" />
            </svg>
            <span><strong>Vaše značka</strong> se objeví přímo v&nbsp;odpovědi AI. Přesně to řeší GEO&nbsp;SEO.</span>
          </figcaption>
        </figure>
      </div>
    </div>
  </Container>
</Section>

<style>
  .hero { position: relative; overflow: hidden; }
  .hero::before {
    content: "";
    position: absolute;
    inset: -25% -10% auto auto;
    width: 40rem;
    height: 40rem;
    background: radial-gradient(circle, var(--color-accent-tint), transparent 62%);
    pointer-events: none;
    z-index: 0;
  }
  .hero__grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 5vw, 4rem);
    align-items: center;
  }
  .hero__content { max-width: 40rem; }
  .hero__eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent-strong);
    margin-bottom: 1rem;
  }
  .hero__title { font-size: clamp(2.1rem, 5.5vw, 3.6rem); font-weight: 700; }
  .hero__hl { color: var(--color-accent-strong); }
  .hero__lead {
    margin: 1.4rem 0 0;
    font-size: clamp(1.05rem, 1.5vw, 1.25rem);
    line-height: 1.6;
    color: var(--color-ink-muted);
  }
  .hero__lead strong { color: var(--color-ink); font-weight: 600; }
  .hero__cta { display: flex; flex-wrap: wrap; gap: 0.875rem; margin-top: 2rem; }
  .hero__quick { display: flex; flex-wrap: wrap; align-items: center; gap: 0.625rem; margin-top: 2rem; }
  .hero__quick-label { font-size: 0.85rem; color: var(--color-ink-faint); }
  .hero__chip {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--color-ink-muted);
    padding: 0.4rem 0.85rem;
    border: 1px solid var(--color-rule-strong);
    border-radius: var(--radius-pill);
    transition: border-color var(--dur-base) var(--ease-out), color var(--dur-base) var(--ease-out), background var(--dur-base) var(--ease-out);
  }
  .hero__chip:hover { border-color: var(--color-accent); color: var(--color-accent-strong); background: var(--color-accent-tint); }

  /* Vizuál — chat scéna „dotaz → odpověď AI → odkaz geo-seo.cz" (předloha: v4-phone-final) */
  .hero__visual { display: flex; flex-direction: column; align-items: center; }

  /* Popisek + šipka — jasně upozorní, co ukázka představuje */
  .visual-cue {
    display: flex; flex-direction: column; align-items: center;
    gap: 0.1rem;
    margin-bottom: 0.35rem;
    text-align: center;
  }
  .visual-cue__label { margin: 0; font-size: 1.1rem; font-weight: 600; color: var(--color-ink); }
  .visual-cue__label strong { color: var(--color-accent-strong); font-weight: 700; }
  .visual-cue__arrow { width: 2.75rem; height: 3rem; color: var(--color-accent-strong); }
  .chat {
    /* Lokální „chatová" modrá (scoped) — záměrně NE konverzní zelená,
       aby zelená zůstala akční/brand barvou a web získal druhý odstín. */
    --chat-blue: oklch(0.56 0.15 256);
    --chat-blue-strong: oklch(0.47 0.16 258);
    --chat-blue-bright: oklch(0.80 0.12 250);
    --chat-blue-tint: oklch(0.95 0.035 255);

    position: relative;
    width: 100%;
    max-width: 23rem;
    display: flex;
    flex-direction: column;
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-card-hover);
    overflow: hidden;
    animation: chat-float 7s ease-in-out infinite;
  }

  /* Hlavička chatu */
  .chat__head {
    display: flex; align-items: center; gap: 0.6rem;
    padding: 0.9rem 1.1rem;
    border-bottom: 1px solid var(--color-rule);
  }
  .chat__avatar {
    display: grid; place-items: center;
    width: 2rem; height: 2rem;
    border-radius: var(--radius-md);
    background: linear-gradient(135deg, var(--chat-blue-bright), var(--chat-blue-strong));
    color: #fff;
  }
  .chat__avatar svg { width: 1.1rem; height: 1.1rem; }
  .chat__name { font-weight: 600; font-size: 0.95rem; color: var(--color-ink); }
  .chat__tag {
    margin-left: auto;
    font-family: var(--font-mono); font-size: 0.6rem; font-weight: 600;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--color-ink-faint);
    padding: 0.2rem 0.5rem;
    border: 1px solid var(--color-rule-strong);
    border-radius: var(--radius-pill);
  }

  /* Vlákno zpráv */
  .chat__thread {
    display: flex; flex-direction: column; gap: 0.7rem;
    padding: 1.1rem;
    background: var(--color-paper-hover);
  }
  .chat__bubble {
    margin: 0;
    max-width: 85%;
    padding: 0.7rem 0.9rem;
    font-size: 0.9rem; line-height: 1.55;
    border-radius: var(--radius-lg);
  }
  .chat__bubble--user {
    align-self: flex-end;
    background: var(--chat-blue-strong); color: #fff;
    border-bottom-right-radius: var(--radius-sm);
    font-weight: 500;
  }
  .chat__bubble--ai {
    align-self: flex-start;
    background: var(--color-paper); color: var(--color-ink-muted);
    border: 1px solid var(--color-rule);
    border-bottom-left-radius: var(--radius-sm);
  }
  .chat__link {
    font-weight: 600; color: var(--chat-blue-strong);
    text-decoration: underline; text-underline-offset: 2px;
    text-decoration-color: var(--chat-blue);
    border-radius: var(--radius-sm);
    padding: 0 0.14em;
    background: var(--chat-blue-tint);
    white-space: nowrap;
    animation: chat-glow 2.6s var(--ease-out) infinite;
  }
  .chat__link--muted { background: none; font-weight: 500; animation: none; white-space: normal; }

  /* Vysvětlující popisek — z ukázky dělá diagram, ne živý chat */
  .chat__note {
    display: flex; align-items: flex-start; gap: 0.55rem;
    margin: 0;
    padding: 0.85rem 1.1rem;
    border-top: 1px solid var(--color-rule);
    font-size: 0.82rem; line-height: 1.45;
    color: var(--color-ink-muted);
  }
  .chat__note svg { width: 1rem; height: 1rem; flex: none; margin-top: 0.1rem; color: var(--chat-blue-strong); }
  .chat__note strong { color: var(--color-ink); font-weight: 600; }

  @keyframes chat-glow {
    0%, 100% { box-shadow: 0 0 0 0 oklch(0.56 0.15 256 / 0.35); }
    50% { box-shadow: 0 0 0 5px oklch(0.56 0.15 256 / 0); }
  }
  @keyframes chat-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .chat, .chat__link { animation: none; }
  }

  @media (min-width: 900px) {
    .hero__grid { grid-template-columns: 1.15fr 0.85fr; }
  }
</style>
