---
/**
 * Container.astro — max-width wrapper s konzistentním horizontálním paddingem.
 * size: section (default, --max-section) | prose (--max-prose) | wide (100%).
 */
interface Props {
  size?: "section" | "prose" | "wide";
  class?: string;
}
const { size = "section", class: cls = "" } = Astro.props;
const max =
  size === "prose" ? "var(--max-prose)" : size === "wide" ? "100%" : "var(--max-section)";
---

<div class:list={["container", cls]} style={`--container-max:${max}`}>
  <slot />
</div>

<style>
  .container {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--space-section-x);
    width: 100%;
  }
</style>
