---
/**
 * Prose.astro — typografický wrapper pro dlouhý obsah (edu stránky).
 * Styly slottovaného obsahu přes :global() (slot scoping gotcha).
 */
interface Props {
  class?: string;
}
const { class: cls = "" } = Astro.props;
---

<div class:list={["prose", cls]}><slot /></div>

<style>
  .prose { max-width: var(--max-prose); }
  .prose :global(h2) {
    font-size: clamp(1.4rem, 2.8vw, 1.9rem);
    font-weight: 700;
    margin: 2.25rem 0 0.85rem;
  }
  .prose :global(h2:first-child) { margin-top: 0; }
  .prose :global(h3) { font-size: 1.2rem; font-weight: 600; margin: 1.75rem 0 0.6rem; }
  .prose :global(p) { margin: 0 0 1.1rem; line-height: 1.7; color: var(--color-ink-muted); }
  .prose :global(ul), .prose :global(ol) { margin: 0 0 1.1rem; padding-left: 1.4rem; line-height: 1.7; color: var(--color-ink-muted); }
  .prose :global(li) { margin-bottom: 0.4rem; }
  .prose :global(li::marker) { color: var(--color-accent); }
  .prose :global(strong) { color: var(--color-ink); font-weight: 600; }
  .prose :global(a) {
    color: var(--color-accent-strong);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: oklch(from var(--color-accent) l c h / 0.4);
    transition: text-decoration-color var(--dur-base) var(--ease-out);
  }
  .prose :global(a:hover) { text-decoration-color: var(--color-accent); }
</style>
