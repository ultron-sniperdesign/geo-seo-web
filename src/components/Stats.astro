---
/**
 * Stats.astro — 3–4 KPI dlaždice (číslo + popisek + „proč to řešit"). Datový tah „Proč teď".
 */
interface StatItem {
  value: string;
  label: string;
  note?: string;
}
interface Props {
  items: StatItem[];
}
const { items } = Astro.props;
---

<dl class="stats">
  {items.map((s) => (
    <div class="stat">
      <dt class="stat__value tnum">{s.value}</dt>
      <dd class="stat__label">{s.label}</dd>
      {s.note && <dd class="stat__note">{s.note}</dd>}
    </div>
  ))}
</dl>

<style>
  .stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem 1.25rem;
    margin: 0;
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding-left: 1rem;
    border-left: 3px solid var(--color-accent);
  }
  .stat__value {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700;
    line-height: 1;
    color: var(--color-accent-strong);
    letter-spacing: -0.02em;
  }
  .stat__label {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.4;
    font-weight: 600;
    color: var(--color-ink);
  }
  .stat__note {
    margin: 0.55rem 0 0;
    padding-top: 0.55rem;
    border-top: 1px solid var(--color-rule);
    font-size: 0.82rem;
    line-height: 1.45;
    color: var(--color-ink-muted);
  }
  @media (min-width: 760px) {
    .stats { grid-template-columns: repeat(4, 1fr); }
  }
</style>
