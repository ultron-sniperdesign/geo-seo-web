---
/**
 * Footer.astro — patička: logo + tagline, sloupce odkazů, copyright, legal.
 */
import Logo from "~/components/Logo.astro";
import Container from "~/components/Container.astro";

const year = new Date().getFullYear();
const cols = [
  {
    title: "GEO",
    links: [
      { label: "Co je GEO", href: "/co-je-geo/" },
      { label: "GEO návod", href: "/geo-navod/" },
      { label: "Platformy", href: "/platformy/" },
    ],
  },
  {
    title: "Služby",
    links: [
      { label: "GEO/SEO Audit", href: "/audit/" },
      { label: "Dlouhodobé SEO", href: "/sluzby/dlouhodobe-seo/" },
      { label: "GEO obsah", href: "/sluzby/geo-obsah/" },
    ],
  },
  {
    title: "Web",
    links: [
      { label: "Blog", href: "/blog/" },
      { label: "Kontakt", href: "/kontakt/" },
      { label: "GDPR", href: "/gdpr/" },
    ],
  },
];
---

<footer class="footer">
  <Container>
    <div class="footer__top">
      <div class="footer__brand">
        <Logo size="sm" />
        <p class="footer__tagline">
          Praktický průvodce GEO (Generative Engine Optimization) — jak vás
          začnou citovat ChatGPT, Perplexity a Google AI.
        </p>
      </div>
      <nav class="footer__cols" aria-label="Patička">
        {cols.map((col) => (
          <div class="footer__col">
            <h2 class="footer__col-title">{col.title}</h2>
            <ul>
              {col.links.map((l) => (
                <li><a href={l.href}>{l.label}</a></li>
              ))}
            </ul>
          </div>
        ))}
      </nav>
    </div>
    <div class="footer__bottom">
      <span>© {year} geo-seo.cz · Sniper Design (CPU s.r.o.)</span>
      <span class="footer__built">postaveno na Astru · hostováno v ČR</span>
    </div>
  </Container>
</footer>

<style>
  .footer {
    background: var(--color-paper-deep);
    border-top: 1px solid var(--color-rule);
    padding-block: clamp(2.5rem, 5vw, 4rem) 1.5rem;
  }
  .footer__top {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  .footer__tagline {
    margin: 0.875rem 0 0;
    max-width: 26rem;
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-ink-muted);
  }
  .footer__cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .footer__col-title {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-faint);
    margin-bottom: 0.75rem;
  }
  .footer__col ul { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.5rem; }
  .footer__col a {
    font-size: 0.9rem;
    color: var(--color-ink-muted);
    transition: color var(--dur-base) var(--ease-out);
  }
  .footer__col a:hover { color: var(--color-accent-strong); }
  .footer__bottom {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.5rem 1.5rem;
    margin-top: 2.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-rule);
    font-size: 0.8rem;
    color: var(--color-ink-faint);
  }
  @media (min-width: 760px) {
    .footer__top { grid-template-columns: 1.4fr 2fr; gap: 3rem; }
  }
</style>
