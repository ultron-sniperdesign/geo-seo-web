---
/**
 * PageLayout.astro (L2) — vnitřní stránky: BaseLayout + PageHeader + slot.
 * `title` = SEO <title> (SERP), `heading` = H1 (může být lidštější — decoupling).
 */
import BaseLayout from "~/layouts/BaseLayout.astro";
import PageHeader from "~/components/PageHeader.astro";

interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
  heading: string;
  lead?: string;
  crumbs?: Crumb[];
  image?: string;
  imageAlt?: string;
  ogType?: "website" | "article";
  jsonLd?: Record<string, unknown>[];
  noindex?: boolean;
}
const { title, description, eyebrow, heading, lead, crumbs = [], image, imageAlt, ogType, jsonLd, noindex } = Astro.props;
---

<BaseLayout title={title} description={description} image={image} imageAlt={imageAlt} ogType={ogType} jsonLd={jsonLd} noindex={noindex}>
  <PageHeader eyebrow={eyebrow} title={heading} lead={lead} crumbs={crumbs} />
  <slot />
</BaseLayout>
