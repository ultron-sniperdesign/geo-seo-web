---
/**
 * BaseLayout.astro (L1) — HTML kostra společná pro celý web:
 * <head> (SEO meta + OG + fonty + favicon) + <Header/> + <slot/> + <Footer/>.
 * SEO/JSON-LD bohatost se doplní postupně (per stránka přes props).
 */
import "~/styles/global.css";
import { site } from "~/i18n/site";
import Header from "~/components/Header.astro";
import Footer from "~/components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  image?: string;
}
const { title, description = site.org.description, image = "/og/default.png" } = Astro.props;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
const ogImage = Astro.site ? new URL(image, Astro.site).href : image;
---

<!doctype html>
<html lang={site.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <link rel="preload" href="/fonts/geist-200-900-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="stylesheet" href="/fonts/fonts.css" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={site.locale} />
    <meta property="og:site_name" content={site.name} />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <a class="skip-link" href="#main">Přeskočit na obsah</a>
    <Header />
    <main id="main"><slot /></main>
    <Footer />
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    left: 0.75rem;
    top: -3.5rem;
    z-index: 100;
    background: var(--color-ink);
    color: var(--color-paper);
    padding: 0.5rem 0.9rem;
    border-radius: var(--radius-md);
    transition: top var(--dur-base) var(--ease-out);
  }
  .skip-link:focus-visible { top: 0.75rem; }
</style>
